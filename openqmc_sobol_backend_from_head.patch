+        const uint64_t domain = qmc_domain_key(seed_, 0x2000u, static_cast<uint64_t>(trial_), static_cast<uint64_t>(step));
+        uint64_t local = 0;
+        for (std::size_t i = 0; i < walkers.size(); ++i) {
+            if (walkers[i].alive) {
+                u_dir[i] = qmc_.sample1D(QmcAddress{domain, local++, 0u});
