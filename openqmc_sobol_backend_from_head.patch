+    }
+    void assign(int, const MixedStripDomain&, const Config&, std::vector<WalkerState>& walkers, std::vector<double>& u_dir) override {
+        for (std::size_t i = 0; i < walkers.size(); ++i) {
+            if (walkers[i].alive) u_dir[i] = rng_.uniform01();
+        }
+    }
