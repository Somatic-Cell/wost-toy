+
+struct QmcRequest {
+    uint64_t domainKey = 0;
+    uint64_t sampleIndex = 0;
+    uint32_t dimension = 0;
+};
+
+class QmcEngine {
+public:
+    explicit QmcEngine(QmcBackend backend = QmcBackend::Simple) : backend_(backend) {
+#ifndef WOST_TOY_USE_OPENQMC
+        if (backend_ == QmcBackend::OpenQmcSobol) {
+            throw std::runtime_error("--qmc-backend openqmc-sobol requested, but this binary was built without WOST_TOY_USE_OPENQMC=ON");
+        }
+#endif
+    }
+
+    QmcBackend backend() const { return backend_; }
+
+    double sample1d(const QmcRequest& req) const {
+        switch (backend_) {
+        case QmcBackend::Simple:
+            return sample1d_simple(req);
+        case QmcBackend::OpenQmcSobol:
+            return sample1d_openqmc_sobol(req);
+        }
+        return sample1d_simple(req);
+    }
+
+    Point2 sample2d(uint64_t domainKey, uint64_t sampleIndex) const {
+        return Point2{ sample1d(QmcRequest{domainKey, sampleIndex, 0u}),
+                       sample1d(QmcRequest{domainKey, sampleIndex, 1u}) };
+    }
+
+private:
+    double sample1d_simple(const QmcRequest& req) const {
+        const double shift = hashed_unit(req.domainKey, static_cast<uint64_t>(req.dimension));
+        return simple_lattice_dimension_sample(req.sampleIndex, req.dimension, shift);
+    }
+
+    double sample1d_openqmc_sobol(const QmcRequest& req) const {
+#ifdef WOST_TOY_USE_OPENQMC
+        // OpenQMC domains provide four high-quality dimensions. For dimensions
+        // beyond 3, derive a child domain per 4D block. Pathwise RQMC therefore
+        // remains a high-dimensional Sobol baseline, while bucketed RQMC can
+        // keep dimension small by assigning a fresh domain per (step, bucket).
+        const uint64_t mixed = hash_combine(req.domainKey, req.dimension / 4u);
+        const int x = static_cast<int>(mixed & 0x7fffffffu);
+        const int y = static_cast<int>((mixed >> 32) & 0x7fffffffu);
+        const int frame = static_cast<int>((mixed >> 17) & 0x7fffffffu);
+        const int index = static_cast<int>(req.sampleIndex & 0x7fffffffu);
+        const int localDim = static_cast<int>(req.dimension % 4u);
+
+        oqmc::SobolSampler domain(x, y, frame, index, nullptr);
+        float sample[4];
+        domain.drawSample<4>(sample);
+        double u = static_cast<double>(sample[localDim]);
+        // Be defensive about exact 1.0 if an implementation ever returns it.
+        if (u >= 1.0) u = std::nextafter(1.0, 0.0);
+        if (u < 0.0) u = 0.0;
+        return u;
+#else
+        (void)req;
+        throw std::runtime_error("OpenQMC Sobol backend was not compiled in");
+#endif
+    }
+
+    QmcBackend backend_ = QmcBackend::Simple;
+};
+
+inline uint64_t qmc_domain_key(uint64_t seed, uint64_t methodTag, uint64_t trial,
+                               uint64_t step, uint64_t bucket, uint64_t extra = 0) {
+    return hash_combine(seed, methodTag, trial, step, bucket, extra);
 }
 
 } // namespace wost
